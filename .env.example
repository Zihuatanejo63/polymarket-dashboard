# ============================================================
# PolyMarket 概率看板小程序 - 环境变量配置
# ============================================================

# -------------------- 数据库配置 --------------------
# PostgreSQL 数据库连接（用于存储用户数据、收藏、定时任务等）
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=polymarket_db

# -------------------- OSS混合云架构配置 --------------------
# 阿里云OSS配置（从OSS读取PolyMarket数据）
# 这是推荐的方案，无需海外服务器，成本约¥10/月
OSS_REGION=oss-ap-southeast-1
OSS_BUCKET=polymarket-data-yourname
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# -------------------- PolyMarket API配置（可选） --------------------
# 以下配置仅在需要直接访问PolyMarket API时使用
# 注意：国内服务器无法直接访问，需要海外服务器或代理

# Dune Analytics API（备用数据源，500次/月限制）
DUNE_API_KEY=your_dune_api_key

# PolyMarket Gamma API
POLYMARKET_API_URL=https://gamma-api.polymarket.com

# Goldsky GraphQL API（备用数据源）
GOLDSKY_API_KEY=your_goldsky_api_key
GOLDSKY_ENDPOINT=https://api.goldsky.com/api/public/project_cl7.../subgraphs/...

# -------------------- 通知服务配置 --------------------
# 微信通知（用于定时报告）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# -------------------- 安全相关 --------------------
# JWT密钥（用户认证）
JWT_SECRET=your_jwt_secret_key

# -------------------- 服务器配置 --------------------
PORT=3000
NODE_ENV=production
